# Required environment variables for the /api/subscribe serverless function.
#
# Set these in your deploy platform's dashboard (Vercel → Project → Settings
# → Environment Variables, or Netlify → Site → Build & deploy → Environment).
# DO NOT commit a real .env file to git — it should be in .gitignore.

# ── Beehiiv ──────────────────────────────────────────────────────────────────
# Get from Beehiiv → Settings → Integrations → API. Requires `subscriptions:write` scope.
BEEHIIV_API_KEY=your-beehiiv-api-key-here

# Format: pub_xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# Find in your Beehiiv dashboard URL, or via the API: GET /v2/publications
BEEHIIV_PUBLICATION_ID=pub_xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
